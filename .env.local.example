# ─── My Home Budapest — environment variables ───────────────────────────────
# Copy this file to `.env.local` and fill in real values when ready.
# The site runs fully on mock data without any of these set.

# Supabase — database + image storage (see supabase/schema.sql and docs/SUPABASE-SETUP.md)
# Settings → API: Project URL + anon public key (safe in browser), service_role (server only!).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Storage bucket the property images are uploaded to (created during setup).
NEXT_PUBLIC_SUPABASE_BUCKET=property-images

# Cloudflare R2 — NOT used; image storage is handled by Supabase Storage above.
# Kept only as a future fallback if storage ever needs to move (10 GB free, no egress).
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# NEXT_PUBLIC_R2_PUBLIC_URL=

# GoHighLevel CRM — lead forms post directly to the Cloudflare Worker
# (cloudflare/myhome-ghl-leads), which creates the contact + opportunity.
# Set this to the deployed Worker URL.
NEXT_PUBLIC_GHL_WORKER_URL=

# Resend — NOT used for leads anymore (GHL owns leads). Kept for possible
# transactional email later.
RESEND_API_KEY=
INQUIRY_NOTIFICATION_EMAIL=myhome@olahkrisztina.hu

# Google Maps (map view + property coordinates)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# DeepL (admin "Fordítás angolra" button). Free key ends with ":fx".
DEEPL_API_KEY=

# Site
NEXT_PUBLIC_SITE_URL=https://myhomebudapest.hu
